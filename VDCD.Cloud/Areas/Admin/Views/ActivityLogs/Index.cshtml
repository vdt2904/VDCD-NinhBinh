@model VDCD.Entities.DTO.PagedResult<VDCD.Entities.DTO.ActivityLogDto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Activity Logs";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

    var totalPages = (int)Math.Ceiling((double)Model.Total / Model.PageSize);
    var stt = (Model.Page - 1) * Model.PageSize + 1;

    var isSearch = !string.IsNullOrEmpty(ViewBag.Content) ||
                   !string.IsNullOrEmpty(ViewBag.TypeText);

    var actionName = isSearch ? "Search" : "Index";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    .settings-container {
        padding: 10px;
    }

    .settings-card {
        border-radius: 10px;
    }

    .settings-header {
        font-size: 15px;
        letter-spacing: 0.5px;
    }

        .settings-header form input {
            border-radius: 6px;
        }

        .settings-header form .btn {
            padding: 4px 10px;
        }

    .badge-log {
        font-size: 12px;
        padding: 6px 10px;
    }
</style>

<div class="settings-container">
    <div class="card settings-card border-0 shadow-sm">

        <!-- Header + Search -->
        <div class="card-header settings-header d-flex justify-content-between align-items-center bg-white">

            <span class="fw-bold">DANH SÁCH ACTIVITY LOG</span>

            <form asp-action="Search" method="get" class="d-flex gap-2" id="searchForm">

                <input type="text"
                       name="Content"
                       value="@ViewBag.Content"
                       class="form-control form-control-sm"
                       style="width:250px;"
                       placeholder="Tìm nội dung..." />

                <select name="TypeText"
                        class="form-select form-select-sm"
                        style="width:200px;">
                    <option value="">-- Tất cả loại --</option>

                    @if (ViewBag.TypeList != null)
                    {
                        foreach (var type in ViewBag.TypeList)
                        {
                            <option value="@type"
                                    selected="@(ViewBag.TypeText == type)">
                                @type
                            </option>
                        }
                    }
                </select>

                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search"></i>
                </button>

                <a asp-action="Index" class="btn btn-secondary btn-sm">
                    Reset
                </a>

            </form>

        </div>

        <!-- Body -->
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle w-100">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px;">STT</th>
                            <th style="width:120px;">Loại</th>
                            <th>Nội dung</th>
                            <th style="width:150px;">User</th>
                            <th style="width:130px;">IP</th>
                            <th style="width:170px;">Thời gian</th>
                        </tr>
                    </thead>

                    <tbody id="logTableBody">
                        @if (Model.Data.Any())
                        {
                            foreach (var item in Model.Data)
                            {
                                <tr>
                                    <td>@stt</td>

                                    <td>
                                        <span class="badge badge-log bg-info text-dark">
                                            @item.TypeText
                                        </span>
                                    </td>

                                    <td>@item.Content</td>
                                    <td>@item.UserName</td>
                                    <td>@item.Ip</td>
                                    <td>@item.CreatedOnDate.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                                stt++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    Không có dữ liệu
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link"
                                   href="@Url.Action(
                                        actionName,
                                        new {
                                            page = i,
                                            pageSize = Model.PageSize,
                                            Content = ViewBag.Content,
                                            TypeText = ViewBag.TypeText
                                        })">
                                    @i
                                </a>
                            </li>
                        }

                    </ul>
                </nav>
            }

        </div>
    </div>
</div>